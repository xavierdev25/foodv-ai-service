# ============================================================
# FoodV AI Service — Variables de entorno
# ============================================================
# Copia este archivo a .env y completa los valores.
# NUNCA commitees el archivo .env real al repositorio.

# Entorno: "development" | "staging" | "production"
# En production las validaciones de seguridad son estrictas (aborta si faltan).
ENV=development

# ----------------------------------------------------------------
# Autenticación — OBLIGATORIO en producción
# ----------------------------------------------------------------
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Mínimo 32 caracteres. NO usar "change-me-in-production".
API_SECRET_KEY=

# ----------------------------------------------------------------
# CORS — separar múltiples orígenes con coma. NUNCA usar "*".
# ----------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:8080

# ----------------------------------------------------------------
# Ollama (modelo LLM local)
# ----------------------------------------------------------------
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=phi3
OLLAMA_TIMEOUT_SECONDS=30

# ----------------------------------------------------------------
# Groq (fallback cloud — opcional)
# ----------------------------------------------------------------
# Obtener en https://console.groq.com
# Si está vacío, no habrá fallback cuando Ollama falle.
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192
GROQ_TIMEOUT_SECONDS=20

# ----------------------------------------------------------------
# Redis (caché)
# ----------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_MAX_CONNECTIONS=50
AI_CACHE_TTL_SECONDS=300

# ----------------------------------------------------------------
# Rate limiting (formato slowapi: "<n>/<period>")
# ----------------------------------------------------------------
RATE_LIMIT_RECOMMENDATIONS=10/minute

# ----------------------------------------------------------------
# Servicio
# ----------------------------------------------------------------
AI_SERVICE_PORT=8001
